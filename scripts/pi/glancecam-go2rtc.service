[Unit]
Description=GlanceCam go2rtc streaming engine
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=glancecam
WorkingDirectory=/opt/glancecam/go2rtc
ExecStart=/opt/glancecam/go2rtc/go2rtc -config /opt/glancecam/go2rtc/go2rtc.yaml
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
